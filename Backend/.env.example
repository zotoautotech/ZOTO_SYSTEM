# Server
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
ALLOWED_ORIGIN=http://localhost:5173

# Google service account (paste the full JSON key contents as one line,
# OR set GOOGLE_APPLICATION_CREDENTIALS to a file path instead)
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=

# Spreadsheet IDs
ZOTO_TRANSACTIONS_SHEET_ID=165xJOwRbXlWm7lzg23O0yP85618UIKVimF-p_AVbkd0
CUSTOMER_BILLING_SHEET_ID=1YQsQki4GBtyuWXJewmGkGk-fX_Yimb_dyI4ydwuPcag
TRANSPORT_SHEET_ID=1B7QuXzAI7FcucAdJhaZigmxJ5HQs77anmOO_EZ_XsjM
FG_SHEET_ID=1Pbsp8ZSpHKrrTTZi0a_ZJsmaevNSsvXYnzosfDVM2aA

# Fiscal year series used for ID generation (e.g. ORD-2627-0001)
FISCAL_YEAR_SERIES=2627

# Google Drive folder for attachments (PO PDFs, invoices, PDI reports…).
# Create a folder in Drive, share it with the service account email as Editor,
# then paste its folder ID here (the long id in the folder's URL). Leave blank
# to upload into the service account's own Drive root (works, but the files
# won't be visible in your own Drive).
DRIVE_FOLDER_ID=
